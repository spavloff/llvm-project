; CHECK: call i1 @llvm.is.fpclass.f32(float %x, /* snan */ i32 1)
; CHECK: call i1 @llvm.is.fpclass.f32(float %x, /* qnan */ i32 2)
; CHECK: call i1 @llvm.is.fpclass.f32(float %x, /* -inf */ i32 4)
; CHECK: call i1 @llvm.is.fpclass.f32(float %x, /* -normal */ i32 8)
; CHECK: call i1 @llvm.is.fpclass.f32(float %x, /* -subnormal */ i32 16)
; CHECK: call i1 @llvm.is.fpclass.f32(float %x, /* -zero */ i32 32)
; CHECK: call i1 @llvm.is.fpclass.f32(float %x, /* +zero */ i32 64)
; CHECK: call i1 @llvm.is.fpclass.f32(float %x, /* +subnormal */ i32 128)
; CHECK: call i1 @llvm.is.fpclass.f32(float %x, /* +normal */ i32 256)
; CHECK: call i1 @llvm.is.fpclass.f32(float %x, /* +inf */ i32 512)
; CHECK: call i1 @llvm.is.fpclass.f32(float %x, /* nan */ i32 3)
; CHECK: call i1 @llvm.is.fpclass.f32(float %x, /* zero */ i32 96)
; CHECK: call i1 @llvm.is.fpclass.f32(float %x, /* subnormal */ i32 144)
; CHECK: call i1 @llvm.is.fpclass.f32(float %x, /* normal */ i32 264)
; CHECK: call i1 @llvm.is.fpclass.f32(float %x, /* inf */ i32 516)
; CHECK: call i1 @llvm.is.fpclass.f32(float %x, /* -zero|-subnormal|-normal */ i32 56)
; CHECK: call i1 @llvm.is.fpclass.f32(float %x, /* +zero|+subnormal|+normal */ i32 448)
; CHECK: call i1 @llvm.is.fpclass.f32(float %x, /* +zero|+subnormal|+normal|+inf */ i32 960)
